---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | Design System Docs</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<nav>
			<div class="nav-header">
				<a href="/" class="brand-logo">DESIGN SYSTEM</a>
			</div>
			<div class="nav-section">
				<div class="nav-section-title">Foundations</div>
				<ul>
					<li><a href="/typography">Typography</a></li>
					<li><a href="/colors">Colors</a></li>
				</ul>
			</div>
			<div class="nav-section">
				<div class="nav-section-title">Components</div>
				<ul>
					<li><a href="/components/button">Button</a></li>
					<li><a href="/components/product-card">Product Card</a></li>
					<li><a href="/components/input-form">Input Form</a></li>
				</ul>
			</div>
		</nav>
		<main>
			<div class="content-wrapper">
				<h1>{title}</h1>
				<slot />
			</div>
		</main>
		<style is:global>
			@font-face {
				font-family: 'Party';
				src: url('/Party-Heavy.otf') format('opentype');
				font-weight: 900;
				font-style: normal;
			}
			@font-face {
				font-family: 'Party';
				src: url('/Party-Bold_20231127 1 1.otf') format('opentype');
				font-weight: 700;
				font-style: normal;
			}
			@font-face {
				font-family: 'Party';
				src: url('/Party-Regular_20231127 1 1.otf') format('opentype');
				font-weight: 400;
				font-style: normal;
			}

			:root {
				--bg-color: #f8f9fa;
				--text-color: #1a1a1a;
				--brand-primary: #e21212;
				--brand-secondary: #006efa;
				--nav-bg: #ffffff;
				--border-color: #eee;
				--sidebar-width: 280px;
			}

			body {
				font-family: 'Manrope', sans-serif;
				margin: 0;
				display: flex;
				background-color: var(--bg-color);
				color: var(--text-color);
				-webkit-font-smoothing: antialiased;
			}

			nav {
				width: var(--sidebar-width);
				background: var(--nav-bg);
				padding: 32px 24px;
				height: 100vh;
				border-right: 1px solid var(--border-color);
				position: sticky;
				top: 0;
				flex-shrink: 0;
				box-sizing: border-box;
				overflow-y: auto;
			}

			.nav-header {
				margin-bottom: 48px;
			}

			.brand-logo {
				font-family: 'Party', sans-serif;
				font-size: 24px;
				font-weight: 900;
				color: var(--brand-primary);
				text-decoration: none;
				letter-spacing: 1px;
			}

			.nav-section {
				margin-bottom: 32px;
			}

			.nav-section-title {
				font-size: 11px;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: #999;
				font-weight: 700;
				margin-bottom: 16px;
				padding-left: 12px;
			}

			nav ul {
				list-style: none;
				padding: 0;
				margin: 0;
			}

			nav li {
				margin: 4px 0;
			}

			nav a {
				display: block;
				padding: 10px 12px;
				border-radius: 8px;
				color: #555;
				text-decoration: none;
				font-weight: 500;
				font-size: 14px;
				transition: all 0.2s;
			}

			nav a:hover {
				background: #f5f5f5;
				color: var(--brand-primary);
			}

			main {
				flex: 1;
				padding: 64px;
				display: flex;
				justify-content: center;
				overflow-y: auto;
			}

			.content-wrapper {
				width: 100%;
				max-width: 1000px;
			}

			h1, h2, h3, h4 {
				font-family: 'Party', sans-serif;
				font-weight: 900;
				margin-top: 0;
				color: #000;
			}

			h1 {
				font-size: 4rem;
				line-height: 1;
				margin-bottom: 48px;
				border: none;
				padding: 0;
			}

			h2 {
				font-size: 2.5rem;
				margin-top: 64px;
				margin-bottom: 24px;
				border-bottom: 2px solid #000;
				padding-bottom: 12px;
			}

			h3 {
				font-size: 1.8rem;
				margin-top: 40px;
			}

			p {
				line-height: 1.6;
				color: #444;
				font-size: 1.1rem;
			}

			section {
				margin-bottom: 80px;
			}
		</style>
	</body>
</html>
